{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": true,
    "jsx": "react",
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": false
  },
  "include": [
    "src/index.ts",
    "src/cli-orchestrator.ts",
    "src/orchestrator/**/*",
    "src/performance/**/*",
    "src/console/ConsoleOutput.ts",
    "src/console/StreamingConsoleOutput.ts",
    "src/console/InteractiveInput.ts",
    "src/console/ContinuousInput.ts",
    "src/console/EnhancedInputHandler.ts",
    "src/console/InputBufferManager.ts",
    "src/console/RawInputHandler.ts",
    "src/figma/FigmaExtractor.ts",
    "src/commands/analyze.ts",
    "src/commands/doctor.ts",
    "src/commands/init.ts",
    "src/commands/mcp-server.ts",
    "src/commands/mcp-config.ts",
    "src/commands/orchestration-commands.ts",
    "src/commands/agent-bridge.ts",
    "src/commands/generate-agents.ts",
    "src/commands/figma-multi-agent.ts",
    "src/config.ts",
    "src/config-manager.ts",
    "src/config/**/*",
    "src/constants/**/*",
    "src/logger.ts",
    "src/auth.ts",
    "src/types/**/*",
    "src/services/agent-detector.ts",
    "src/services/agent-file-generator.ts",
    "src/services/agent-prompt-builder.ts",
    "src/services/agent-prompt-service.ts",
    "src/services/agent-revival.ts",
    "src/services/ask-service.ts",
    "src/services/claude-output-parser.ts",
    "src/services/context-builder.ts",
    "src/services/repository-analyzer.ts",
    "src/services/repository-context-extractor.ts",
    "src/services/request-builder.ts",
    "src/services/task-executor.ts",
    "src/services/task-prompt-builder.ts",
    "src/services/thread-service.ts",
    "src/services/tmux-config.ts",
    "src/services/tmux-tips.ts",
    "src/utils/agent-config-manager.ts",
    "src/utils/claude-agents-revival.ts",
    "src/utils/claude-detector.ts",
    "src/utils/claude-sdk-diagnostics.ts",
    "src/utils/context-detector.ts",
    "src/utils/debug.ts",
    "src/utils/doctor.ts",
    "src/utils/git-worktree-manager.ts",
    "src/utils/graphyn-folder.ts",
    "src/utils/logger.ts",
    "src/utils/repository-detector.ts",
    "src/utils/retry.ts",
    "src/utils/system-check.ts",
    "src/utils/task-file-generator.ts",
    "src/utils/thread-api.ts",
    "src/utils/tmux-cockpit-orchestrator.ts",
    "src/utils/tmux-layout-manager.ts",
    "src/utils/token-manager.ts",
    "src/utils/desktop-bridge.ts",
    "src/ui/upsell-prompt.ts",
    "src/mcp/server-discovery.ts",
    "src/mcp/server-installer.ts",
    "src/mcp/server-registry.ts",
    "src/engines/SpecializationEngine.ts",
    "src/engines/standalone-engine.ts",
    "src/claude/**/*",
    "src/clyde/**/*",
    "src/coordinator/**/*",
    "src/git/**/*",
    "src/api/client.ts",
    "src/context/context7-integration.ts",
    "src/context/index.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "scripts/*.sh",
    "tests/**/*"
  ]
}